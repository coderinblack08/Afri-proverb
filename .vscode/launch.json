{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "train",
      "type": "python",
      "request": "launch",
      "module": "accelerate.commands.launch",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "./src:${env:PYTHONPATH}",
        "CUDA_VISIBLE_DEVICES": "0",
        "WANDB_PROJECT": "debugs"
      },
      "justMyCode": false,
      "args": [
        "--num_processes=1",
        "--mixed_precision=fp16",
        "-m",
        "proverb.commands.train",
        "--config-file",
        "configs/default.yaml"
      ]
    },
    {
      "name": "evaluate",
      "type": "python",
      "request": "launch",
      "module": "accelerate.commands.launch",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "./src:${env:PYTHONPATH}",
        "CUDA_VISIBLE_DEVICES": "0",
        "WANDB_PROJECT": "debugs"
      },
      "justMyCode": false,
      "args": [
        "--num_processes=1",
        "--mixed_precision=bf16",
        "-m",
        "proverb.commands.evaluate",
        "--config",
        "configs/default.yaml",
        "--learning_rate",
        "1e-4",
        "--location=Kenya",
        "--language=maasai"
      ]
    },
    {
      "name": "preprocess",
      "type": "python",
      "request": "launch",
      "program": "${workspaceFolder}/preprocess/dataset_preprocess-T.py",
      "console": "integratedTerminal",
      "args": [
        "--process-image"
      ],
      "cwd": "${workspaceFolder}"
    },
    {
      "name": "train_ft_peft",
      "type": "python",
      "request": "launch",
      "module": "accelerate.commands.launch",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "./src:${env:PYTHONPATH}",
        "CUDA_VISIBLE_DEVICES": "0",
        "WANDB_PROJECT": "debugs"
      },
      "justMyCode": false,
      "args": [
        "--num_processes=1",
        "--mixed_precision=fp16",
        "-m",
        "csi_slt.commands.train_ft_peft",
        "engine.training_args.report_to=none",
        "engine.training_args.auto_output_root=./outputs/debug_outputs",
        "engine.training_args.dataloader_num_workers=0"
      ]
    },
    {
      "name": "train_ft",
      "type": "python",
      "request": "launch",
      "module": "accelerate.commands.launch",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "./src:${env:PYTHONPATH}",
        "CUDA_VISIBLE_DEVICES": "0",
        "WANDB_PROJECT": "debugs"
      },
      "justMyCode": false,
      "args": [
        "--num_processes=1",
        "--mixed_precision=fp16",
        "-m",
        "csi_slt.commands.train_ft",
        "engine.training_args.report_to=none",
        "engine.training_args.auto_output_root=./outputs/debug_outputs",
        "engine.training_args.dataloader_num_workers=0"
      ]
    },
    {
      "name": "eval",
      "type": "python",
      "request": "launch",
      "module": "accelerate.commands.launch",
      "console": "integratedTerminal",
      "env": {
        "PYTHONPATH": "./src:${env:PYTHONPATH}",
        "CUDA_VISIBLE_DEVICES": "0,1",
        "WANDB_PROJECT": "debugs"
      },
      "justMyCode": false,
      "args": [
        "--num_processes=2",
        "--mixed_precision=fp16",
        "-m",
        "csi_slt.commands.evaluate",
        "engine.training_args.dataloader_num_workers=4"
      ]
    }
  ]
}
